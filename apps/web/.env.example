# Copy this file to .env.local and fill in your values
# Supabase keys: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Ishaan's Express backend URL
# Local dev:  http://localhost:3000
# Production: https://your-backend-url.com (update when Ishaan deploys)
VITE_API_URL=http://localhost:3000

# USDA FoodData Central API key (https://fdc.nal.usda.gov/api-key-signup.html)
# Used by LogFoodModal for fallback food search when the local foods table has no match
VITE_USDA_API_KEY=your-usda-api-key-here
