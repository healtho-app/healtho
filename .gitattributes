# Healtho repo line-ending policy
# Stops Windows checkouts from flipping LF to CRLF and producing phantom diffs.
# Added 2026-04-24 as pre-migration cleanup commit B of C.

# Default: auto-detect text vs binary, store text as LF in repo, leave LF on checkout
* text=auto eol=lf

# ── Explicit text files (LF) ─────────────────────────────────────────────────
*.js       text eol=lf
*.jsx      text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.mjs      text eol=lf
*.cjs      text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.html     text eol=lf
*.svg      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.toml     text eol=lf
*.sh       text eol=lf
*.sql      text eol=lf
*.csv      text eol=lf
*.env.example text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.nvmrc     text eol=lf

# ── Windows scripts MUST be CRLF ─────────────────────────────────────────────
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# ── Binary files (no normalization, no diffs) ────────────────────────────────
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.ico      binary
*.mp4      binary
*.webm     binary
*.mov      binary
*.wav      binary
*.mp3      binary
*.ogg      binary
*.docx     binary
*.xlsx     binary
*.xls      binary
*.pdf      binary
*.zip      binary
*.gz       binary
*.tar      binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.otf      binary
